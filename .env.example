# .env.example - Template for Local Development
# Copy to .env.local and replace placeholder values with actual credentials

# Agent Configuration
AGENT_TYPE=task                    # task, merge_request, branch_review
TASK_TYPE=custom                   # custom (uses AI_TASK_PROMPT/AI_TASK_FILE),
                                   # security_audit, quality_report, dependency_check;
                                   # other values use general analysis
TASK_SCOPE=external_tools          # full_project, main_branch, recent_changes, external_tools

# AI Provider Configuration
AI_PROVIDER=gemini                 # gemini, openai, claude
GEMINI_API_KEY=your-gemini-api-key-here
# AI_MODEL=gemini-3-flash-preview  # Optional: override default model

# Task Definition (choose one)
# Option 1: DSPy YAML task file (recommended for complex tasks)
# AI_TASK_FILE='.gitlab/prompts/my_task.yml'

# Option 2: Inline prompt (use single quotes to preserve formatting)
AI_TASK_PROMPT='Analyze the system using available MCP tools and generate a comprehensive report.'

# Context7 API Key (get yours from https://context7.com)
# For local dev: set the value here. For GitLab CI: configure CONTEXT7_API_KEY
# as a masked CI/CD variable (Settings → CI/CD → Variables, enable "Mask variable")
CONTEXT7_API_KEY=your-context7-api-key-here

# MCP Server Configuration (JSON array, use single quotes)
# In GitLab CI, use $CONTEXT7_API_KEY (resolved from masked CI variable)
# For local dev, use ${CONTEXT7_API_KEY} (resolved from env var above)
MCP_SERVERS_CONFIG='[{"name":"context7","protocol":"http","endpoint":"https://mcp.context7.com/mcp","headers":{"CONTEXT7_API_KEY":"${CONTEXT7_API_KEY}"},"timeout":300,"idle_timeout":60}]'

# No MCP servers (generic AI analysis without external tools)
# MCP_SERVERS_CONFIG='[]'

# Logging Configuration
LOG_LEVEL=DEBUG
JSON_LOGS=false

# Optional: Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
