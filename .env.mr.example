# .env.mr.example - MR Review Agent for Local Development
# Copy to .env.mr and replace placeholder values

# Agent Configuration
AGENT_TYPE=merge_request

# Target MR Configuration
CI_MERGE_REQUEST_IID=123
CI_PROJECT_ID=your-group/your-project
CI_API_V4_URL=https://gitlab.example.com/api/v4

# GitLab API Access (requires api or read_api + read_repository scopes)
GITLAB_TOKEN=your-gitlab-token-here

# AI Provider Configuration
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here

# MCP Server Configuration (optional)
# Context7 for library documentation lookups during review
MCP_SERVERS_CONFIG='[{"name":"context7","protocol":"http","endpoint":"https://mcp.context7.com/mcp","timeout":300,"idle_timeout":60}]'

# Review Prompt (optional - override built-in review prompt)
# AI_TASK_PROMPT='You are an expert code reviewer. Focus on security and performance.'

# Or use a DSPy task file
# AI_TASK_FILE='.gitlab/prompts/mr_code_review.yml'

# Logging
LOG_LEVEL=DEBUG
JSON_LOGS=false

# Optional: Slack notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
